# =============================================================================
# Supabase（本番・Vercel）
# =============================================================================
# ダッシュボード → Connect → ORM: Prisma の手順に沿って URI をコピーしてください。
#
# DATABASE_URL … Transaction pooler（ポート 6543）。末尾に ?pgbouncer=true を付ける（未付与なら追加）。
# DIRECT_URL … Session pooler または Direct（ポート 5432）。マイグレーション / prisma db push 用。
#
# 例（値はすべてダッシュボードのものに置き換え）:
# DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
# Direct のみ使う場合（IPv6 などが使える環境）の DIRECT_URL 例:
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
# Vercel では Production に DATABASE_URL と DIRECT_URL の両方を登録してください（ビルド後の検証・CLI と整合）。
#
# 実際の URL・パスワードは .env にだけ書く（このファイルはテンプレ用。リポジトリに載せない）。
# ローカルで prisma / next を動かすときも読み込まれるのは .env です。
#
# DATABASE_URL=
# DIRECT_URL=

# セッション署名用（16文字以上・本番では必ずランダムに変更）
AUTH_SECRET="change-me-to-a-long-random-string"

# 任意: デフォルト営業時間（DB未設定時のフォールバック）
# BUSINESS_OPEN_TIME=09:00
# BUSINESS_CLOSE_TIME=18:00
# SLOT_MINUTES=30
# RESERVATION_DURATION_MINUTES=60

# シード用管理者パスワード（省略時は admin1234）
# SEED_ADMIN_PASSWORD=your-secure-password

# =============================================================================
# ローカル PostgreSQL（docker-compose など）
# =============================================================================
# Supabase を使わない場合は DATABASE_URL と DIRECT_URL を同じ接続にします。
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/carcare?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/carcare?schema=public"
